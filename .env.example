GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
PORT=8000

# API Security
API_KEY=                        # B2B static key sent in X-API-Key header (leave blank to disable)
MAX_BODY_BYTES=1048576          # max request body size in bytes (default 1 MB)
RATE_LIMIT_RPM=20               # max POST requests per minute per IP
ALLOWED_ORIGINS=*               # comma-separated domains for CORS, e.g. https://yoursite.com
